{
  "team": "",
  "budget": {
    "poll": "0.10",
    "planning": "1.00",
    "implementing": "3.00",
    "plan_review": "10.00",
    "review": "10.00"
  },
  "max_turns": {
    "planning": 30,
    "implementing": 50,
    "plan_review": 30,
    "review": 30
  },
  "model": {
    "default": "sonnet",
    "planning": "sonnet",
    "implementing": "sonnet",
    "plan_review": "sonnet",
    "pr": "haiku",
    "review": "opus"
  },
  "log_dir": "/path/to/logs",
  "lock_dir": "/path/to/lock",
  "worktree_dir": "/path/to/worktrees",
  "max_concurrent": 3,
  "lock_timeout_min": 60,
  "sandbox": {
    "enabled": true,
    "autoAllowBashIfSandboxed": true,
    "allowUnsandboxedCommands": false,
    "filesystem": {
      "denyRead": [
        "~/.ssh",
        "~/.aws",
        "~/.gnupg",
        "~/.bash_history",
        "~/.zsh_history",
        "~/.netrc",
        "~/.docker",
        "~/.kube",
        "~/.local/share/atuin",
        "~/.secrets",
        "~/.1password",
        "~/.codex",
        "~/.pki",
        "~/.config/gcloud",
        "~/.config/op",
        "~/.terraform.d",
        "~/.gsutil",
        "~/.local/config",
        "~/.antigravity-server"
      ]
    },
    "network": {
      "allowManagedDomainsOnly": true,
      "allowedDomains": [
        "api.linear.app",
        "github.com",
        "*.github.com",
        "*.githubusercontent.com",
        "api.anthropic.com"
      ]
    }
  }
}
